{
    "build":  {
                  "frontendDist":  "../dist",
                  "beforeBuildCommand":  "pnpm build",
                  "devUrl":  "http://localhost:5173",
                  "beforeDevCommand":  "pnpm exec vite"
              },
    "version":  "0.1.0",
    "bundle":  {
                   "windows":  {
                                   "wix":  null
                               },
                   "active":  true,
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "targets":  "all"
               },
    "app":  {
                "windows":  [
                                {
                                    "width":  1200,
                                    "height":  800,
                                    "minWidth":  800,
                                    "fullscreen":  false,
                                    "devtools":  true,
                                    "minHeight":  600,
                                    "title":  "PenTip",
                                    "resizable":  true,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "identifier":  "com.pentip.app",
    "productName":  "PenTip",
    "$schema":  "../node_modules/@tauri-apps/cli/config.schema.json"
}