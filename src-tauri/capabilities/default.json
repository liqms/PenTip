{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "log:default",
    {
      "identifier": "sql:allow-load",
      "allow": [{ "db": "sqlite:pentip.db" }]
    },
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "db": "sqlite:pentip.db" }]
    },
    {
      "identifier": "sql:allow-select",
      "allow": [{ "db": "sqlite:pentip.db" }]
    }
  ]
}
